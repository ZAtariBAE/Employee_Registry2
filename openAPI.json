    },
    "/employees/{id}/status": {
      "patch": {
        "summary": "Update employee status",
        "tags": [
          "Employees"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Unique ID of the employee"
          }
        ],
        "requestBody": {
          "required": true,
          "description": "The updated status field",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "description": "The employment status",
                    "enum": [
                      "active",
                      "inactive"
                    ],
                    "example": "active"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success (Status updated)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Employee status updated successfully"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Employee"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Error (JSON formatting incorrect)",
            "content": {
              "application/json": {
                "schema": null,
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "example": "Bad Request"
                  },
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "example": "Malformed JSON payload."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Error (Not Found)",
            "content": {
              "application/json": {
                "schema": null,
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "example": "Employee not found"
                  }
                }
              }
            }
          },
          "422": {
            "description": "Error (Improper Request Body)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Improper Request Body"
                    },
                    "data": null,
                    "type": "array",
                    "items": {
                      "type": "string",
                      "example": "Status must be text."
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error (Server Error)",
            "content": {
              "application/json": {
                "schema": null,
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
