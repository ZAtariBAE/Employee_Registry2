                "properties": {
                  "message": {
                    "type": "string",
                    "example": "Internal Error"
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Deletes an employee record",
        "tags": [
          "Employees"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Unique ID of the employee"
          }
        ],
        "responses": {
          "204": {
            "description": "Success (Employee Deleted)"
          },
          "404": {
            "description": "Error (Not Found)",
            "content": {
              "application/json": {
                "schema": null,
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
