          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "department",
                  "salary"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "The employee's full name",
                    "example": "John Doe"
                  },
                  "department": {
                    "type": "string",
