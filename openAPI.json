                    "example": "Finance"
                  },
                  "salary": {
                    "type": "number",
                    "description": "Value of employee's salary",
                    "example": 1234.5
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Optional email of employee",
                    "example": "name@gmail.com"
                  }
                }
              }
            }
          }
        }
      },
