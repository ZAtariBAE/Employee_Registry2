              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Improper Request Body"
                    },
                    "data": null,
                    "type": "array",
                    "items": {
                      "type": "string",
                      "example": "Salary must be a number."
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error (Server Error)",
            "content": {
              "application/json": {
                "schema": null,
