          "400": {
            "description": "Error (JSON formatting incorrect)",
            "content": {
              "application/json": {
                "schema": null,
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "example": "Bad Request"
                  },
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "example": "Malformed JSON payload."
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Error (Not Found)",
            "content": {
              "application/json": {
                "schema": null,
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "example": "Employee not found"
                  }
                }
              }
            }
          },
          "422": {
            "description": "Error (Improper Request Body)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
